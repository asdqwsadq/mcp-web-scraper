# NVIDIA NIM API配置（免费额度，从 https://build.nvidia.com 注册）
NVIDIA_API_KEY=nvapi-你的key
NVIDIA_MODEL=qwen/qwen3.5-122b-a10b

# Tavily Search API Key（免费额度每月1000次，从 https://tavily.com 注册）
TAVILY_API_KEY=tvly-dev-你的key

# XPack 配置（如果启用XPack计费）
XPACK_API_URL=http://xpack-mcp-market:8002
XPACK_ADMIN_URL=http://xpack-mcp-market:8001

# 本地API Key（降级方案，用于本地测试）
LOCAL_API_KEYS=test_key:test_user

# 服务器配置
PORT=8080
